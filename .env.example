# Database
DATABASE_URL=postgresql://synapse:synapse@localhost:5432/synapse

# Redis (optional — only for local worker: USE_WORKER=true)
REDIS_URL=redis://localhost:6379/0
USE_WORKER=false

# NVIDIA AI (server-only)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# PubMed / NCBI (required for production — use your lab email)
NCBI_TOOL=synapse
NCBI_EMAIL=you@your-university.edu
PUBMED_MAX_RESULTS=30

# Reliability
ANALYSIS_STALE_MS=600000
RATE_LIMIT_PER_MINUTE=60
PDF_MAX_SIZE_MB=25

# Security
JWT_SECRET=change-me-in-production
AUTH_ENABLED=false

# =============================================================================
# Dependencies & package managers
# =============================================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Environment & secrets (never commit)
# =============================================================================
.env
.env.*
!.env.example
!.env.local.example

# =============================================================================
# Next.js / build output
# =============================================================================
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# =============================================================================
# Testing & coverage
# =============================================================================
coverage/
.nyc_output/
.vitest/
htmlcov/
.coverage
*.lcov

# =============================================================================
# Database & local infra
# =============================================================================
drizzle/meta/
postgres_data/
*.db
*.sqlite

# =============================================================================
# Uploads & user content
# =============================================================================
uploads/
*.pdf

# =============================================================================
# Docker (local volumes only — keep docker-compose.yml)
# =============================================================================
.docker/

# =============================================================================
# Vercel & deployment
# =============================================================================
.vercel/

# =============================================================================
# Logs & debug
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# OS & editor (local only)
# =============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
.idea/
*.swp
*.swo
*~

# =============================================================================
# Python (legacy / local scripts — not part of deployed app)
# =============================================================================
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# =============================================================================
# AI assistants — tooling, sessions, plans (written or used by AI)
# Do not commit Cursor/Copilot/Claude session or plan artifacts.
# =============================================================================
.cursor/
**/.cursor/
agent-transcripts/
**/agent-transcripts/
*.plan.md
**/*.plan.md
.plans/
**/.plans/
.aider*
.continue/
.copilot/
.codex/
.claude/
*.ai.md
*-draft.md
*-ai-draft.*
.ai/
.ai-cache/
**/.ai/

# AI-generated planning & deployment notes (keep README + source code)
# Remove a line below if you want that file in git.
agents.md
DEPLOY.md
AGENTS.md
RTK.md

